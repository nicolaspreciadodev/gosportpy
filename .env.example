# Archivo de ejemplo de variables de entorno para GoSport
# Renombra este archivo a .env y completa los valores correctos para despliegue

DEBUG=False
SECRET_KEY=TU_SECRET_KEY_SEGURO_AQUI
ALLOWED_HOSTS=127.0.0.1,localhost,.tu-dominio.com

# URL de la base de datos PostgreSQL
# Formato: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://tu_user:tu_password@localhost:5432/gosport_db

# Configuración opcional de correo para Reset de Password (Opcional por ahora)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tu_correo@gmail.com
# EMAIL_HOST_PASSWORD=tu_app_password
# EMAIL_USE_TLS=True
