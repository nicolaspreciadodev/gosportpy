# Archivo de ejemplo de variables de entorno para GoSport
# Renombra este archivo a .env y completa los valores correctos para despliegue

DEBUG=True
SECRET_KEY=tu_secret_key_super_segura
ALLOWED_HOSTS=127.0.0.1,localhost

# Configuración de Correo Electrónico (Requerido para Mails en Producción)
# Si lo omites en local, la consola de django imprimirá los correos (fallback backend console).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

MERCADOPAGO_ACCESS_TOKEN=TEST-111111111111-mock-access-token
MERCADOPAGO_PUBLIC_KEY=TEST-mock-public-key
# EMAIL_USE_TLS=True
